# === Required: Generate with `openssl rand -hex 32` ===
KEY_ENCRYPTION_SECRET=

# === Database (docker-compose defaults, override if using external DB) ===
DATABASE_URL="postgresql://aggregator:changeme@postgres:5432/llm_aggregator?schema=public"
DB_USER=aggregator
DB_PASSWORD=changeme
DB_NAME=llm_aggregator

# === Redis ===
REDIS_URL="redis://redis:6379"

# === App ===
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# === Provider API Keys (at least one for the platform to work) ===
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# === Proxy for geo-restricted providers (Anthropic from China needs this) ===
# Set to your proxy URL, e.g. http://your-vps:7890 or a Clash instance
ANTHROPIC_PROXY=
